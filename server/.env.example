# ============================================
# FaithGuard Server — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Server port (Render will set this automatically)
PORT=5000

# Frontend URL (for CORS — set to your Vercel deployment URL in production)
CLIENT_URL=http://localhost:3000

# Firebase Admin SDK — Choose ONE method:

# Method 1: Path to service account JSON file (for local development)
# Download from: Firebase Console > Project Settings > Service Accounts > Generate new private key
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# Method 2: Service account JSON as a string (for Render deployment)
# Paste the entire JSON content of your service account key here
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}
